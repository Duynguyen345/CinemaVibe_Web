# Cấu hình môi trường – Copy file này thành .env và điền thông tin của bạn

# Cổng server (mặc định 3000)
PORT=3000

# Thông tin MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=cinevibe_db

# JWT Secret (đổi thành chuỗi bí mật bất kỳ, càng dài càng tốt)
JWT_SECRET=cinevibe_super_secret_key_2025_change_this

# Thời gian JWT hết hạn
JWT_EXPIRES_IN=7d
